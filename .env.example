# ========================================
# SETI 2026 - Configuração de Ambiente
# ========================================

# Servidor
PORT=3000
NODE_ENV=development

# ========================================
# Banco de Dados MySQL
# ========================================
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=sua_senha_aqui
DB_NAME=seti_2026

# ========================================
# Sessão
# ========================================
# Gere um valor aleatório seguro:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=seu_segredo_aleatorio_aqui

# ========================================
# OpenRouter (Chat com IA)
# ========================================
# Obtenha em: https://openrouter.ai/
OPENROUTER_API_KEY=sk-or-v1-sua_chave_aqui
OPENROUTER_MODEL=openrouter/free

# ========================================
# Admin (Fallback de Autenticação)
# ========================================
# Usado como fallback se nenhum usuário for encontrado
# Formato: email=admin, senha=valor abaixo
ADMIN_PASSWORD=sua_senha_admin_aqui

# ========================================
# Site
# ========================================
SITE_URL=http://localhost:3000
APP_NAME=SETI 2026

# ========================================
# Logging (Opcional)
# ========================================
LOG_LEVEL=info
